# Lead Radar — optional configuration.
# Copy to .env for local runs, or add these as repo Secrets in GitHub
# (Settings -> Secrets and variables -> Actions) for the daily cron.
# EVERYTHING here is optional. With none set, Lead Radar runs 100% free.

# --- Raises free-source limits (recommended, still free) ---
# A GitHub personal access token (classic, no scopes needed) lifts the
# GitHub Search API rate limit from ~10 to ~30 requests/min, so the GitHub
# source pulls more new repos per run. In GitHub Actions this is injected
# automatically as secrets.GITHUB_TOKEN — you only need to set this for
# LOCAL runs. Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Paid enrichers (optional; fill phone / verified email / firmographics) ---
# Each is a no-op when blank, so leaving them empty keeps the $0 path working.
# Enrichment runs only on the top-scored leads to conserve credits.

# Hunter.io — finds contact emails for a company domain.
# Get a key: https://hunter.io/api-keys  (free tier ~25 searches/mo)
HUNTER_API_KEY=

# Apollo.io — organization enrichment: phone, employee count, industry, location.
# Get a key: https://developer.apollo.io/  (paid)
APOLLO_API_KEY=

# Crunchbase — funding + firmographics lookup by company name.
# Get a key: https://data.crunchbase.com/  (paid)
CRUNCHBASE_API_KEY=

# --- Tuning ---
# How many top-scored leads to run through paid enrichers per daily run.
# Bounds API credit spend. Default 25.
ENRICH_TOP_N=25
